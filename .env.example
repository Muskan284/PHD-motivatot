# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Green API — personal WhatsApp connection
# Create a free instance at https://green-api.com
GREEN_API_INSTANCE_ID=your_instance_id_here
GREEN_API_TOKEN=your_api_token_here

# WhatsApp group chat ID
# Get this from Green API dashboard → your instance → getChats
# Format for groups: XXXXXXXXXXX@g.us
WHATSAPP_GROUP_CHAT_ID=your_group_chat_id_here

# Timezone (default: Asia/Kolkata)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kolkata
